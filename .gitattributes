* text=auto eol=lf

*.blade.php diff=html
*.css diff=css
*.html diff=html
*.md diff=markdown
*.php diff=php

/.github export-ignore
CHANGELOG.md export-ignore
.styleci.yml export-ignore

# Built frontend assets are committed (Node-less deploy host) but generated —
# don't expand them in diffs; mark them generated so GitHub collapses them.
public/build/** -diff linguist-generated
